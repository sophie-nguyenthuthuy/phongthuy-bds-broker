# ─── API ──────────────────────────────────────────────────────────
ENV=dev
API_HOST=0.0.0.0
API_PORT=8000
API_SECRET_KEY=change-me-in-prod-please-32+chars-random
API_CORS_ORIGINS=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────
POSTGRES_USER=phongthuy
POSTGRES_PASSWORD=phongthuy_dev
POSTGRES_DB=phongthuy_bds
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://phongthuy:phongthuy_dev@localhost:5432/phongthuy_bds

# ─── Redis (job queue) ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Storage ──────────────────────────────────────────────────────
# Local filesystem in dev; S3-compatible in prod.
STORAGE_BACKEND=local
STORAGE_LOCAL_PATH=./storage
# S3_ENDPOINT_URL=https://s3.cloudfly.vn
# S3_BUCKET=phongthuy-bds-prod
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ─── DLCN (NĐ 13/2023/NĐ-CP) ──────────────────────────────────────
# Retention mặc định 90 ngày, có thể override theo hợp đồng tenant.
DLCN_RETENTION_DAYS=90
DLCN_ENCRYPTION_KEY=base64-encoded-32-byte-key-fernet-format-here

# ─── Auth ─────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MIN=60
JWT_REFRESH_TTL_DAYS=14

# ─── Billing (VN payment gateways) ────────────────────────────────
# VNPay
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_API_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/billing/vnpay-return

# MoMo
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=

# ─── OCR ──────────────────────────────────────────────────────────
OCR_BACKEND=paddleocr           # paddleocr | google_vision | mock
PADDLEOCR_LANG=vi
GOOGLE_APPLICATION_CREDENTIALS=

# ─── Web ──────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=Phong Thủy BĐS

# ─── Observability ────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json                 # json | console
SENTRY_DSN=
